# Docker server runtime variables (example)
PORT=8080
MONGO_URI=mongodb://mongo:27017/THE_COLLAGE
JWT_SECRET=replace_with_strong_secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_email_app_password
FIREBASE_PROJECT_ID=your_firebase_project_id
FRONTEND_URL=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8080

# Chatbot provider
# Use gemini for free-tier usage. Use openai for OpenAI-compatible endpoints.
CHATBOT_PROVIDER=gemini
CHATBOT_API_KEY=your_provider_api_key

# Gemini defaults (recommended)
# CHATBOT_API_URL can be empty to auto-build based on model.
CHATBOT_API_URL=
CHATBOT_MODEL=gemini-1.5-flash

# OpenAI-compatible example
# CHATBOT_PROVIDER=openai
# CHATBOT_API_URL=https://api.openai.com/v1/chat/completions
# CHATBOT_MODEL=gpt-4o-mini
CHATBOT_TEMPERATURE=0.4
